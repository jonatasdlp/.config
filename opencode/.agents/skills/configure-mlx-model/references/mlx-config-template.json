{
  "_comment": "Template based on user's working opencode.json configuration",
  "schema": "https://opencode.ai/config.json",
  "model": "mlx-lm/mlx-community/MODEL-NAME",
  "provider_examples": {
    "mlx-lm_multi_model": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX LM",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "mlx-community/gemma-4-e4b-it-qat-OptiQ-4bit": {
          "name": "mlx-community/gemma-4-e4b-it-qat-OptiQ-4bit"
        },
        "mlx-community/gemma-4-e2b-it-qat-OptiQ-4bit": {
          "name": "mlx-community/gemma-4-e2b-it-qat-OptiQ-4bit"
        }
      }
    },
    "mlx_single": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX (local)",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "Default"
        }
      }
    },
    "ollama_compatible": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "model-name": {
          "name": "model-name"
        }
      }
    }
  },
  "model_naming_conventions": {
    "mlx_community": "mlx-community/MODEL-NAME-[VARIANT]-[quantization]",
    "examples": [
      "mlx-community/gemma-4-e4b-it-qat-OptiQ-4bit",
      "mlx-community/Meta-Llama-3-8B-Instruct-4bit",
      "mlx-community/qwen3.5-9b-4bit"
    ]
  },
  "validation_rules": {
    "npm_must_be": "@ai-sdk/openai-compatible",
    "mlx_base_url": "http://localhost:8080/v1",
    "ollama_base_url": "http://localhost:11434/v1",
    "no_trailing_commas": true,
    "valid_json": true
  }
}

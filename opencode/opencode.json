{
  "$schema": "https://opencode.ai/config.json",
  "model": "omlx/gemma-4-e4b-it-OptiQ-4bit",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${OPENCODE_KEY}"
      ],
      "enabled": false
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Gemma4:e2b (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:e2b": {
          "name": "gemma4:e2b"
        }
      }
    },
    "mlx-lm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX LM",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "mlx-community/gemma-4-e4b-it-qat-OptiQ-4bit": {
          "name": "mlx-community/gemma-4-e4b-it-qat-OptiQ-4bit"
        },
        "mlx-community/gemma-4-e2b-it-qat-OptiQ-4bit": {
          "name": "mlx-community/gemma-4-e2b-it-qat-OptiQ-4bit"
        },
        "mlx-community/Qwen3.5-9B-MLX-4bit": {
          "name": "mlx-community/Qwen3.5-9B-MLX-4bit"
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "${OMLX_KEY}"
      },
      "models": {
        "gemma-4-e4b-it-OptiQ-4bit": {
          "name": "gemma-4-e4b-it-OptiQ-4bit",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "attachment": true,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  }
}
